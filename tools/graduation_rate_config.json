  "formulas": {
    "_comment": "核心计算公式说明",
    "单次技能期望伤害": {
      "公式": "E = (会心期望 × 会心率 + 会意期望 × 会意率 + 普通期望 × 普通占比 + 擦伤期望 × 擦伤占比) × 次数",
      "会心期望": "max攻 × 攻击倍率 × (1 + 会心伤害加成) × 穿透增伤 × 增伤系数",
      "会意期望": "max攻 × 攻击倍率 × (1 + 会意伤害加成) × 穿透增伤 × 增伤系数",
      "普通期望": "avg攻 × 攻击倍率 × 穿透增伤 × 增伤系数",
      "擦伤期望": "min攻 × 攻击倍率 × 0.5 × 穿透增伤 × 增伤系数"
    },
    "穿透增伤": {
      "公式": "1 + (穿透值 - 怪物防御) / 100",
      "说明": "穿透 > 防御时产生正增伤，否则为负"
    },
    "DPS": {
      "公式": "DPS = 总期望伤害 / 战斗时间(秒)"
    },
    "毕业率": {
      "公式": "毕业率 = 当前DPS / 毕业档DPS × 100%",
      "说明": "毕业档DPS由Excel中的基准配置决定，代表满装备的标准DPS值"
    },
    "105阶完整期望公式": {
      "说明": "每行技能的期望 = (会心期望BK + 会意期望BL + 普通期望 + 擦伤期望BO + 特殊效果BP) × 次数P × 蓄力加成",
      "BK_会心期望": "会心期望 = max攻 × AH穿透增伤 × AI固伤 × (1+AP_外攻加成) × (1+AQ_外攻伤害) × BK系数",
      "BM_会意期望": "会意期望 = max攻 × AH × AI × (1+AP) × (1+AQ) × BM系数"
    }
  }
}
